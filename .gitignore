# Root safety net for local work. Backend and frontend also keep their own repo-level ignores.
.env
.env.*
!.env.example

node_modules/
dist/
coverage/
**/node_modules/
**/dist/
**/coverage/
**/.vite/
**/.cache/
**/.turbo/
**/.parcel-cache/
**/*.tsbuildinfo
*.log

backend/node_modules/
backend/.env
backend/.env.*
!backend/.env.example

frontend/node_modules/
frontend/dist/
frontend/prototipo/node_modules/
frontend/prototipo/dist/
frontend/.env
frontend/.env.*
!frontend/.env.example

# Mobile signing and CI secrets
*.jks
*.keystore
*.mobileprovision
*.p8
*.p12
frontend/android/keystore.properties
frontend/ios/App/App/GoogleService-Info.plist
frontend/ios/App/App/*.entitlements.local
