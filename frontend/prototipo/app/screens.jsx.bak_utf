// SCREEN 9 ГӮВ· PestaГғВұa Ajustes
// ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
function SettingsScreen({ onNavigate }) {
  const SUPPORT_URL = 'https://tu-link-de-soporte.com';
  const planOptions = [
    { id: 'free', name: 'Gratuito', price: 'вӮ¬0 / mes', perks: ['30 generaciones por dГӯa', 'Sugerencias base', 'Soporte estГЎndar'] },
    { id: 'pro', name: 'Pro', price: 'вӮ¬8.99 / mes', perks: ['300 generaciones por dГӯa', 'Tonos premium', 'Historial ampliado'] },
    { id: 'pro-max', name: 'Pro Max', price: 'вӮ¬17.99 / mes', perks: ['Generaciones casi ilimitadas', 'Tonos avanzados por contacto', 'Soporte prioritario'] },
  ];

  const [sheet, setSheet] = React.useState(null); // billing | language | terms | logout
  const [notificationsEnabled, setNotificationsEnabled] = React.useState(true);
  const [language, setLanguage] = React.useState('EspaГұol (EspaГұa)');
  const [plan, setPlan] = React.useState('free');
  const [cardHolder, setCardHolder] = React.useState('Carlos MГ©ndez');
  const [cardNumber, setCardNumber] = React.useState('4242 4242 4242 4242');
  const cardReady = cardHolder.trim().length > 0 && cardNumber.replace(/\s/g, '').length >= 12;
  const currentPlan = planOptions.find(p => p.id === plan) || planOptions[0];

  const openSupport = () => {
    window.open(SUPPORT_URL, '_blank', 'noopener,noreferrer');
  };

  return (
    <>
      <AppHeader title="Ajustes" />
      <div className="scroll-y">
        <div style={{padding: 16}}>
          <div className="card" style={{padding: 0, overflow: 'hidden'}}>
            <button
              onClick={() => setSheet('billing')}
              style={{
                width: '100%', display: 'flex', alignItems: 'center', gap: 14,
                padding: '14px 16px', background: 'transparent', border: 'none',
                borderBottom: '1px solid var(--border)', cursor: 'pointer', textAlign: 'left',
              }}
            >
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--gray-50)', color: 'var(--text-secondary)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Card size={17} /></span>
              <div className="col" style={{flex: 1, gap: 2}}>
                <span style={{fontSize: 15, fontWeight: 500}}>Plan y facturaciГіn</span>
                <span className="t-caption">{currentPlan.name} В· {currentPlan.price}</span>
              </div>
              <Icons.Chevron size={16} sw={2} style={{color: 'var(--text-tertiary)'}} />
            </button>

            <div style={{
              width: '100%', display: 'flex', alignItems: 'center', gap: 14,
              padding: '14px 16px', borderBottom: '1px solid var(--border)',
            }}>
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--gray-50)', color: 'var(--text-secondary)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Bell size={17} /></span>
              <div className="col" style={{flex: 1, gap: 2}}>
                <span style={{fontSize: 15, fontWeight: 500}}>Notificaciones</span>
                <span className="t-caption">{notificationsEnabled ? 'Encendidas' : 'Apagadas'}</span>
              </div>
              <button
                onClick={() => setNotificationsEnabled(v => !v)}
                aria-label="Cambiar estado de notificaciones"
                style={{
                  width: 50, height: 30, borderRadius: 999, border: '1px solid var(--border)',
                  background: notificationsEnabled ? 'var(--accent)' : 'var(--gray-200)',
                  position: 'relative', cursor: 'pointer',
                }}
              >
                <span style={{
                  width: 24, height: 24, borderRadius: 12, background: '#fff',
                  position: 'absolute', top: 2, left: notificationsEnabled ? 23 : 2,
                  transition: 'left 180ms ease',
                }} />
              </button>
            </div>

            <button
              onClick={() => setSheet('language')}
              style={{
                width: '100%', display: 'flex', alignItems: 'center', gap: 14,
                padding: '14px 16px', background: 'transparent', border: 'none',
                borderBottom: '1px solid var(--border)', cursor: 'pointer', textAlign: 'left',
              }}
            >
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--gray-50)', color: 'var(--text-secondary)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Globe size={17} /></span>
              <div className="col" style={{flex: 1, gap: 2}}>
                <span style={{fontSize: 15, fontWeight: 500}}>Idioma de la app</span>
                <span className="t-caption">{language}</span>
              </div>
              <Icons.Chevron size={16} sw={2} style={{color: 'var(--text-tertiary)'}} />
            </button>

            <button
              onClick={openSupport}
              style={{
                width: '100%', display: 'flex', alignItems: 'center', gap: 14,
                padding: '14px 16px', background: 'transparent', border: 'none',
                borderBottom: '1px solid var(--border)', cursor: 'pointer', textAlign: 'left',
              }}
            >
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--gray-50)', color: 'var(--text-secondary)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Help size={17} /></span>
              <div className="col" style={{flex: 1, gap: 2}}>
                <span style={{fontSize: 15, fontWeight: 500}}>Soporte</span>
                <span className="t-caption">Abrir enlace de soporte</span>
              </div>
              <Icons.Chevron size={16} sw={2} style={{color: 'var(--text-tertiary)'}} />
            </button>

            <button
              onClick={() => setSheet('terms')}
              style={{
                width: '100%', display: 'flex', alignItems: 'center', gap: 14,
                padding: '14px 16px', background: 'transparent', border: 'none',
                cursor: 'pointer', textAlign: 'left',
              }}
            >
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--gray-50)', color: 'var(--text-secondary)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Doc size={17} /></span>
              <div className="col" style={{flex: 1, gap: 2}}>
                <span style={{fontSize: 15, fontWeight: 500}}>TГ©rminos legales</span>
                <span className="t-caption">TГ©rminos y condiciones aceptados</span>
              </div>
              <Icons.Chevron size={16} sw={2} style={{color: 'var(--text-tertiary)'}} />
            </button>
          </div>

          <div className="card" style={{marginTop: 16, padding: 0, overflow: 'hidden'}}>
            <button
              onClick={() => setSheet('logout')}
              style={{
                width: '100%', display: 'flex', alignItems: 'center', gap: 14,
                padding: '14px 16px', background: 'transparent', border: 'none',
                cursor: 'pointer', textAlign: 'left', color: 'var(--danger)',
              }}
            >
              <span style={{
                width: 32, height: 32, borderRadius: 8,
                background: 'var(--danger-soft)', color: 'var(--danger)',
                display: 'inline-flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
              }}><Icons.Logout size={17} /></span>
              <span style={{fontSize: 15, fontWeight: 500}}>Cerrar sesiГіn</span>
            </button>
          </div>

          <div style={{textAlign: 'center', padding: '32px 0 16px', display: 'flex', flexDirection: 'column', gap: 4}}>
            <span className="t-caption">WaFli В· v0.1.4 (build 142)</span>
            <a href="#" className="t-caption" style={{color: 'var(--accent)', textDecoration: 'none'}}>Estado del servicio вҶ’</a>
          </div>
        </div>
      </div>
      <BottomNav active="settings" onChange={onNavigate} />

      <BottomSheet open={sheet === 'billing'} onClose={() => setSheet(null)} height="88%">
        <div style={{display: 'flex', flexDirection: 'column', flex: 1, padding: '6px 18px 18px'}}>
          <div className="row gap-2" style={{alignItems: 'center', marginBottom: 10}}>
            <Icons.Card size={18} style={{color: 'var(--accent)'}} />
            <span className="t-h3">Plan y facturaciГіn</span>
          </div>
          <label className="t-small" style={{marginBottom: 6, fontWeight: 500}}>Nombre en la tarjeta</label>
          <input value={cardHolder} onChange={e => setCardHolder(e.target.value)} placeholder="Ej. Carlos MГ©ndez" style={{width: '100%', border: '1px solid var(--border-strong)', borderRadius: 12, padding: '11px 12px', outline: 'none', fontSize: 15, marginBottom: 12, fontFamily: 'inherit'}} />
          <label className="t-small" style={{marginBottom: 6, fontWeight: 500}}>NГәmero de tarjeta</label>
          <input value={cardNumber} onChange={e => setCardNumber(e.target.value)} placeholder="4242 4242 4242 4242" inputMode="numeric" style={{width: '100%', border: '1px solid var(--border-strong)', borderRadius: 12, padding: '11px 12px', outline: 'none', fontSize: 15, marginBottom: 14, fontFamily: 'inherit'}} />
          <div className="card" style={{padding: 12, marginBottom: 12, background: 'var(--gray-50)'}}>
            <span className="t-small" style={{fontWeight: 600}}>Elegir plan</span>
            <div className="col gap-2" style={{marginTop: 10}}>
              {planOptions.map(p => {
                const active = p.id === plan;
                return (
                  <button
                    key={p.id}
                    onClick={() => setPlan(p.id)}
                    style={{
                      width: '100%',
                      border: `1.5px solid ${active ? 'var(--accent)' : 'var(--border)'}`,
                      borderRadius: 12, padding: '10px 11px',
                      background: active ? 'var(--accent-softer)' : 'var(--bg)',
                      textAlign: 'left', cursor: 'pointer',
                    }}
                  >
                    <div className="row" style={{justifyContent: 'space-between', alignItems: 'center', marginBottom: 6}}>
                      <span style={{fontSize: 14.5, fontWeight: 600}}>{p.name}</span>
                      <span className="t-caption" style={{fontWeight: 600}}>{p.price}</span>
                    </div>
                    <span className="t-caption" style={{color: 'var(--text-secondary)'}}>{p.perks[0]}</span>
                  </button>
                );
              })}
            </div>
          </div>
          <button className="btn btn--primary btn--md" style={{marginTop: 'auto', opacity: cardReady ? 1 : 0.55}} disabled={!cardReady} onClick={() => setSheet(null)}>
            Guardar cambios
          </button>
        </div>
      </BottomSheet>

      <BottomSheet open={sheet === 'language'} onClose={() => setSheet(null)} height="58%">
        <div style={{display: 'flex', flexDirection: 'column', flex: 1, padding: '6px 18px 18px'}}>
          <div className="row gap-2" style={{alignItems: 'center', marginBottom: 10}}>
            <Icons.Globe size={18} style={{color: 'var(--accent)'}} />
            <span className="t-h3">Idioma de la app</span>
          </div>
          {['EspaГұol (EspaГұa)', 'EspaГұol (LatinoamГ©rica)', 'English (US)'].map(opt => (
            <button
              key={opt}
              onClick={() => { setLanguage(opt); setSheet(null); }}
              style={{
                width: '100%',
                border: `1px solid ${language === opt ? 'var(--accent)' : 'var(--border)'}`,
                borderRadius: 12, padding: '12px 14px',
                background: language === opt ? 'var(--accent-softer)' : 'var(--bg)',
                textAlign: 'left', cursor: 'pointer', marginBottom: 8,
              }}
            >
              <span style={{fontSize: 14.5, fontWeight: 500}}>{opt}</span>
            </button>
          ))}
        </div>
      </BottomSheet>

      <BottomSheet open={sheet === 'terms'} onClose={() => setSheet(null)} height="88%">
        <div style={{display: 'flex', flexDirection: 'column', flex: 1, padding: '6px 18px 18px'}}>
          <div className="row gap-2" style={{alignItems: 'center', marginBottom: 10}}>
            <Icons.Doc size={18} style={{color: 'var(--accent)'}} />
            <span className="t-h3">TГ©rminos y condiciones</span>
          </div>
          <div className="card scroll-y" style={{padding: 14, background: 'var(--gray-50)', lineHeight: 1.45, fontSize: 13.5}}>
            <p style={{margin: '0 0 10px'}}><b>Contrato de uso de WaFli</b></p>
            <p style={{margin: '0 0 10px'}}>1. El usuario acepta el uso de sugerencias generadas por IA bajo su propio criterio.</p>
            <p style={{margin: '0 0 10px'}}>2. WaFli no envГӯa mensajes automГЎticamente: siempre requiere acciГіn explГӯcita del usuario.</p>
            <p style={{margin: '0 0 10px'}}>3. El usuario puede cancelar su plan cuando lo desee desde la secciГіn de facturaciГіn.</p>
            <p style={{margin: '0 0 10px'}}>4. Se procesan metadatos mГӯnimos para operar el servicio y mejorar la experiencia.</p>
            <p style={{margin: 0}}>Estado: <b>Aceptado</b> В· Fecha: 05/05/2026</p>
          </div>
        </div>
      </BottomSheet>

      <BottomSheet open={sheet === 'logout'} onClose={() => setSheet(null)} height="42%">
        <div style={{display: 'flex', flexDirection: 'column', flex: 1, padding: '8px 18px 18px'}}>
          <span className="t-h3" style={{marginBottom: 6}}>Cerrar sesiГіn</span>
          <p className="t-small" style={{margin: '0 0 14px', color: 'var(--text-secondary)'}}>
            ВҝSeguro que quieres cerrar sesiГіn en este dispositivo?
          </p>
          <div className="col gap-2" style={{marginTop: 'auto'}}>
            <button className="btn btn--primary btn--md" onClick={() => { setSheet(null); onNavigate('landing'); }}>SГӯ, cerrar sesiГіn</button>
            <button className="btn btn--secondary btn--md" onClick={() => setSheet(null)}>Cancelar</button>
          </div>
        </div>
      </BottomSheet>
    </>
  );
}

Object.assign(window, {
  LandingScreen, AuthScreen, LegalAcceptanceScreen, SpanishVariantScreen, ToneBaseScreen, ConnectScreen, ConnectedSuccessScreen, AddToHomeScreen, StaticInfoScreen, ChatsListScreen, ChatScreen,
  SuggestSheet, OpenerSheet, PlanScreen, QuotaExhausted, SettingsScreen,
  Spinner,
});



