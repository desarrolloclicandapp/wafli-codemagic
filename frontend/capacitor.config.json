{
  "appId": "com.wafli.app",
  "appName": "WaFli",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "ios": {
    "scheme": "WaFli"
  },
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    },
    "SocialLogin": {
      "providers": {
        "google": true,
        "apple": true,
        "facebook": false
      }
    }
  }
}
