{
  "name": "wafli-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:copy": "npx cap copy",
    "cap:copy:android": "npx cap copy android",
    "cap:copy:ios": "npx cap copy ios",
    "ios:prepare:codemagic": "bash scripts/prepare-ios-codemagic.sh",
    "android:assemble:debug": "cd android && gradlew.bat assembleDebug --no-daemon",
    "android:bundle:release": "cd android && gradlew.bat bundleRelease --no-daemon",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-firebase/analytics": "^7.3.1",
    "@capacitor/android": "^7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7",
    "@capacitor/ios": "^7",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/push-notifications": "^7.0.6",
    "@capgo/capacitor-social-login": "^7.9.0",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "firebase": "^11.10.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.11"
  }
}
