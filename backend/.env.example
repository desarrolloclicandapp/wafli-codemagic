PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/wafli
PGSSLMODE=disable
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false

# Email / system notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_NAME=waflow.ai
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WaFli <notifications@waflow.ai>
SMTP_TLS_REJECT_UNAUTHORIZED=false

# OAuth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=
APPLE_CLIENT_IDS=

# WhatsApp runtime
WA_RUNTIME_MODE=combined
WA_WORKER_ID=worker_local_1
WA_TASK_POLL_INTERVAL_MS=1000
WA_BROWSER_NAME=WaFli
WA_BROWSER_PLATFORM=macos
WA_INIT_TIMEOUT_MS=240000
WA_SOCKET_CONNECT_TIMEOUT_MS=45000
WA_PROXY_SOCKET_CONNECT_TIMEOUT_MS=90000
WA_RUNTIME_OPEN_TIMEOUT_MS=60000
WA_SEND_READY_TIMEOUT_MS=60000
WA_DEFAULT_QUERY_TIMEOUT_MS=30000
WA_KEEP_ALIVE_INTERVAL_MS=20000
WA_RETRY_REQUEST_DELAY_MS=750
WA_PAIRING_CODE_ENABLED=true
WA_PAIRING_SOCKET_READY_TIMEOUT_MS=15000
WA_PAIRING_PROXY_SOCKET_READY_TIMEOUT_MS=90000
WA_PAIRING_REQUIRE_QR_READY=true
WA_PAIRING_REQUEST_DELAY_MS=1000
WA_PAIRING_READY_FALLBACK_MS=2500
WA_QR_TIMEOUT_MS=120000
WA_PAIRING_CODE_TTL_MS=180000
WA_CONTENT_CACHE_POLICY=ephemeral_ttl
WA_MESSAGE_CACHE_RETENTION_DAYS=7
WA_MESSAGE_BODY_MAX_CHARS=4000
WA_MEDIA_CACHE_MAX_BYTES=5242880
WA_MEDIA_DOWNLOAD_TIMEOUT_MS=45000
WA_PAIRING_RESUME_BASE_DELAY_MS=2500
WA_PAIRING_RESUME_MAX_ATTEMPTS=4
WA_PAIRING_GUARD_ENABLED=true
WA_PAIRING_GUARD_WINDOW_MINUTES=15
WA_PAIRING_GUARD_MAX_ATTEMPTS=4
WA_PAIRING_GUARD_COOLDOWN_MINUTES=30
WA_RECONNECT_BASE_DELAY_MS=5000
WA_RECONNECT_MAX_ATTEMPTS=6
WA_RESTORE_CONNECTED_SESSIONS=true
WA_FETCH_LATEST_VERSION=true
WA_FORCE_BAILEYS_VERSION=
WA_USE_PROXY=false
USE_PROXY=false
WA_PROXY_URL=
WA_PROXY_HTTPS_URL=
WA_DNS_RESULT_ORDER=ipv4first
WA_PROXY_STICKY_SESSION=true
WA_WORKER_HEALTH_ENABLED=true

# OpenAI
AI_PROVIDER=openai
AI_PROMPT_VERSION=wafli-es-v0.4.0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MODEL_SUGGEST=gpt-5-mini
OPENAI_MODEL_REWRITE=gpt-5-mini
OPENAI_MODEL_OPENER=gpt-5-mini
OPENAI_MODEL_REACTIVATE=gpt-5-mini
OPENAI_MODEL_ANALYZE=gpt-5-mini
OPENAI_MODEL_RECOMMEND=gpt-5-mini
# Familia gpt-5: razonamiento y verbosidad (opcionales, con default en codigo).
OPENAI_REASONING_EFFORT=minimal
OPENAI_REASONING_EFFORT_QUALITY=low
OPENAI_VERBOSITY=low
AI_CONTEXT_MESSAGE_LIMIT=24
AI_CONTEXT_LIMIT_SUGGEST=24
AI_CONTEXT_LIMIT_REWRITE=12
AI_CONTEXT_LIMIT_OPENER=12
AI_CONTEXT_LIMIT_REACTIVATE=30
AI_CONTEXT_LIMIT_ANALYZE=24
AI_CONTEXT_LIMIT_RECOMMEND=24
AI_MEDIA_CONTEXT_LIMIT=3
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Quotas
WFL_FREE_DAILY_MESSAGES=5
WFL_PLUS_MONTHLY_MESSAGES=150
WFL_PLUS_TRIAL_DAYS=7
WFL_TOPUP_PACK_SIZE=50
WFL_PRO_MONTHLY_MESSAGES=0

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PACK_50=

# Web push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@wafli.app
